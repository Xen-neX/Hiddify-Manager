#!/bin/bash
#ln -sf $(pwd)/hiddify-warp.service /etc/systemd/system/hiddify-warp.service
source /opt/hiddify-manager/common/utils.sh
systemctl disable hiddify-warp.service >/dev/null 2>&1

function check_wireguard_connection() {
  echo "Checking WARP ..."
  if ! [ -f "wgcf-account.toml" ]; then
    mv wgcf-account.toml wgcf-account.toml.backup
    ./wgcf register --accept-tos -m hiddify -n $(hostname) >/dev/null 2>&1
  fi
  ./wgcf update >/dev/null 2>&1 || return $?
  generate_warp_config
  systemctl restart wg-quick@warp
  echo "Starting WARP.... checking real connectivitiy"
  sleep .5
  if ! real_test; then
    sleep .5
    echo "Checking real connectivitiy again!"
    real_test || return $?
  fi
}
function real_test() {
  curl -s --interface warp --connect-timeout .5 http://ip-api.com?fields=message,country,org,query
  error=$?
  if [ $error == 0 ];then
    success "WARP is WORKING!"
  else 
    warning  "WARP is not working!"
  fi
  return $error
}

function generate_warp_config() {
  echo "Generating WARP config..."
  ./wgcf generate >/dev/null 2>&1
  sed -i 's/\[Peer\]/Table = off\n\[Peer\]/g' wgcf-profile.conf
  
  # Check if IPv6 is available on the host
  curl -6 --connect-timeout 1 -s https://v6.ident.me/ 2>&1 >/dev/null
  ipv6_available=$?
  
  if [ $ipv6_available != 0 ] || [ $(cat /proc/sys/net/ipv6/conf/all/disable_ipv6) == 1 ]; then
    echo "Removing IPV6 from WARP..."
    sed -i '/Address = [0-9a-fA-F:]\{4,\}/s/^/# /' wgcf-profile.conf
  else
    # IPv6 is available, add routing rules for it
    echo "IPv6 is available, configuring WARP with IPv6 support..."
    
    # Extract IPv6 address from config
    ipv6_addr=$(grep -oP 'Address = [^,]+, \K[0-9a-fA-F:]+/\d+' wgcf-profile.conf | head -1)
    
    if [ -n "$ipv6_addr" ]; then
      # Add PostUp/PostDown rules for IPv6 routing
      sed -i "/^MTU = /a PostUp = ip -6 route add default dev warp table 51820\nPostUp = ip -6 rule add from ${ipv6_addr} table 51820 pref 1000\nPostUp = ip -6 rule add oif warp table 51820 pref 999\nPostDown = ip -6 rule del oif warp table 51820 pref 999\nPostDown = ip -6 rule del from ${ipv6_addr} table 51820 pref 1000\nPostDown = ip -6 route del default dev warp table 51820" wgcf-profile.conf
    fi
  fi
  
  sed -i '/DNS = 1.1.1.1/s/^/# /' wgcf-profile.conf
  mkdir -p /etc/wireguard/
  ln -sf $(pwd)/wgcf-profile.conf /etc/wireguard/warp.conf
  systemctl enable wg-quick@warp
  
  # Clean up old IPv6 rules before restart (prevents "File exists" errors)
  ip -6 rule del pref 999 2>/dev/null || true
  ip -6 rule del pref 1000 2>/dev/null || true
  ip -6 route del default dev warp table 51820 2>/dev/null || true
}

# if [[ $warp_mode == 'disabled' ]];then
#   bash disable.sh
# else

#api.zeroteam.top/warp?format=./wgcf for change warp
export WGCF_LICENSE_KEY="{{hconfigs['warp_plus_code']}}"
if ! check_wireguard_connection; then
  mv wgcf-account.toml wgcf-account.toml.backup
  if ! check_wireguard_connection; then
    mv wgcf-account.toml wgcf-account.toml.backup
    export WGCF_LICENSE_KEY=
    if ! check_wireguard_connection; then
      error "!!!!!!!!!!!!!!! WARP ERROR"
    fi
  fi
fi


